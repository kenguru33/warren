# Warren reverse proxy — local-CA mode.
# Caddy serves a static leaf cert generated by `warren setup` (via openssl)
# with the LAN IP as a SubjectAltName, plus an optional DNS SAN if the
# operator chose a custom hostname during setup.
# Each LAN device installs the CA once via http://<lan-ip>/ca.crt.
#
# Variables ({$VAR}) are resolved by Caddy at config load from the
# container's environment (populated by docker compose from docker/.env).
#
# WARREN_UPSTREAM  — host:port that Caddy proxies to (Next.js UI)

{
	auto_https disable_redirects
}

# Plaintext :80 — only used to serve the CA download (chicken-and-egg:
# clients need it before they can validate HTTPS) and to redirect the rest
# of the surface to HTTPS. ESP32 firmware reaches the API over HTTPS now.
:80 {
	# Public CA download. Plaintext on purpose: chicken-and-egg — clients
	# need this file before they can trust HTTPS.
	handle /ca.crt {
		root * /srv
		file_server
		header Content-Type application/x-x509-ca-cert
		header Content-Disposition "attachment; filename=warren-ca.crt"
	}

	# Everything else: redirect to HTTPS on whatever hostname/IP the
	# client originally used. Preserves the URL the user typed.
	handle {
		redir https://{host}{uri} 308
	}
}

# HTTPS :443 — catch-all listener. The leaf cert at /etc/caddy/tls/server.crt
# has the LAN IP as a SubjectAltName, so SNI=<lan-ip> validates. Listening on
# :443 (not on a name-bound site address) sidesteps Caddy's "bare IPs in
# site blocks are listener bindings, not virtual hosts" gotcha.
:443 {
	tls /etc/caddy/tls/server.crt /etc/caddy/tls/server.key
	reverse_proxy {$WARREN_UPSTREAM}
}
