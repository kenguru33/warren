# Warren reverse proxy — Let's Encrypt mode (DNS-01 challenge).
# Caddy obtains a publicly-trusted leaf cert via the configured DNS
# provider's API. No per-device CA install needed.
#
# Variables ({$VAR}) are resolved by Caddy at config load from the
# container's environment (populated by docker compose from docker/.env).
#
# WARREN_DOMAIN        — public domain you own (e.g. warren.bernt.dev)
# WARREN_ACME_EMAIL    — contact email for ACME registration
# WARREN_DNS_PROVIDER  — caddy-dns provider name (default: cloudflare)
# WARREN_DNS_TOKEN     — API token for the DNS provider
# WARREN_UPSTREAM      — host:port that Caddy proxies to (Next.js UI)
#
# This file ONLY validates inside the custom warren-caddy image built by
# `warren setup` (the stock caddy image lacks the DNS provider plugin).
# `caddy validate` against caddy:2.10-alpine will fail with
# "module not registered: dns.providers.<provider>" — that's expected.

# Plaintext :80 — passes device endpoints through, 308-redirects everything
# else to HTTPS. No /ca.crt route here — the cert is publicly trusted.
:80 {
	@device_static path /api/sensors/announce /api/sensors/config/*
	handle @device_static {
		reverse_proxy {$WARREN_UPSTREAM}
	}

	@device_reading path_regexp ^/api/sensors/[^/]+/reading$
	handle @device_reading {
		reverse_proxy {$WARREN_UPSTREAM}
	}

	handle {
		redir https://{$WARREN_DOMAIN}{uri} 308
	}
}

# HTTPS :443 — main user surface. Caddy obtains a Let's Encrypt cert via
# the configured DNS provider's API.
{$WARREN_DOMAIN} {
	tls {$WARREN_ACME_EMAIL} {
		dns {$WARREN_DNS_PROVIDER} {$WARREN_DNS_TOKEN}
	}
	reverse_proxy {$WARREN_UPSTREAM}
}
