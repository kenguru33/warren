#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PID_FILE="$SCRIPT_DIR/.warren.pid"
SENSOR_SECRETS="$SCRIPT_DIR/firmware/sensor/include/secrets.h"
CAMERA_SECRETS="$SCRIPT_DIR/firmware/camera/include/secrets.h"
UI_ENV="$SCRIPT_DIR/ui/.env"
INFLUXDB_TOKEN_FILE="$SCRIPT_DIR/docker/admin.token"
MQTT_PASSWORDFILE="$SCRIPT_DIR/docker/mosquitto/config/passwordfile"
SQLITE_DATA_DIR="$SCRIPT_DIR/ui/.data"
MQTT_CONF="$SCRIPT_DIR/docker/mosquitto/config/mosquitto.conf"

usage() {
    echo "Usage: warren <command> [options]"
    echo ""
    echo "Commands:"
    echo "  setup           Generate config files, install deps, and build UI"
    echo "  start [--dev]   Start infrastructure and UI (--dev for dev mode)"
    echo "  stop            Stop infrastructure and UI"
    echo "  cleanup         Stop everything, wipe all data, secrets, and tokens"
    echo ""
    exit 1
}

prompt() {
    local var="$1" msg="$2" val=""
    while [[ -z "$val" ]]; do
        IFS= read -r -p "$msg: " val
        [[ -z "$val" ]] && echo -e "${RED}  Cannot be empty.${NC}"
    done
    printf -v "$var" '%s' "$val"
}

prompt_secret() {
    local var="$1" msg="$2" val=""
    while [[ -z "$val" ]]; do
        IFS= read -r -s -p "$msg: " val
        echo ""
        [[ -z "$val" ]] && echo -e "${RED}  Cannot be empty.${NC}"
    done
    printf -v "$var" '%s' "$val"
}

setup() {
    echo -e "${BOLD}Warren — Setup${NC}"
    echo "Generates firmware secrets.h files and ui/.env from your answers below."
    echo ""

    existing=()
    [[ -f "$SENSOR_SECRETS" ]]      && existing+=("firmware/sensor/include/secrets.h")
    [[ -f "$CAMERA_SECRETS" ]]      && existing+=("firmware/camera/include/secrets.h")
    [[ -f "$UI_ENV" ]]              && existing+=("ui/.env")
    [[ -f "$INFLUXDB_TOKEN_FILE" ]] && existing+=("docker/admin.token")

    if [[ ${#existing[@]} -gt 0 ]]; then
        echo -e "${YELLOW}These config files already exist:${NC}"
        printf '  %s\n' "${existing[@]}"
        echo ""
        IFS= read -r -p "Overwrite? [y/N] " confirm
        [[ "$confirm" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 1; }
        echo ""
    fi

    prompt        WIFI_SSID    "WiFi SSID"
    prompt_secret WIFI_PASS    "WiFi secret"
    prompt_secret UI_PASS      "UI login password"
    prompt        BACKEND_HOST "Backend host  (IP or hostname, e.g. 192.168.1.100 or warren.local)"

    BACKEND_HOST="${BACKEND_HOST#http://}"
    BACKEND_HOST="${BACKEND_HOST#https://}"
    BACKEND_HOST="${BACKEND_HOST%%/*}"
    MQTT_SERVER="${BACKEND_HOST%%:*}"
    BACKEND_URL="http://${MQTT_SERVER}:3000"

    _rand() { openssl rand -base64 48 | tr -d '\n/+=' | cut -c1-"$1" 2>/dev/null \
              || LC_ALL=C tr -dc 'A-Za-z0-9' < /dev/urandom | head -c"$1"; }

    MQTT_PASS="$(_rand 32)"
    SESSION_PASS="$(_rand 48)"

    INFLUXDB_TOKEN="apiv3_$(openssl rand -hex 32 2>/dev/null || LC_ALL=C tr -dc 'a-f0-9' < /dev/urandom | head -c64)"

    INFLUXDB_URL="http://localhost:8086"
    INFLUXDB_DATABASE="warren"
    if [[ -f "$UI_ENV" ]]; then
        _val="$(grep -m1 '^INFLUXDB_URL='      "$UI_ENV" | cut -d= -f2-)" && [[ -n "$_val" ]] && INFLUXDB_URL="$_val"
        _val="$(grep -m1 '^INFLUXDB_DATABASE=' "$UI_ENV" | cut -d= -f2-)" && [[ -n "$_val" ]] && INFLUXDB_DATABASE="$_val"
    fi

    cat > "$INFLUXDB_TOKEN_FILE" <<EOF
{"name":"admin","token":"${INFLUXDB_TOKEN}"}
EOF

    docker run --rm -e MQTT_PASS="$MQTT_PASS" eclipse-mosquitto:2 \
        sh -c 'mosquitto_passwd -b -c /tmp/pf admin "$MQTT_PASS" >/dev/null 2>&1 && cat /tmp/pf' \
        > "$MQTT_PASSWORDFILE"

    cat > "$MQTT_CONF" <<'EOF'
per_listener_settings true

listener 1883 0.0.0.0
listener_allow_anonymous false
password_file /mosquitto/config/passwordfile

listener 1884 0.0.0.0
listener_allow_anonymous true
EOF

    cat > "$SENSOR_SECRETS" <<EOF
#define SECRET_SSID     "${WIFI_SSID}"
#define SECRET_PASS     "${WIFI_PASS}"

#define MQTT_SERVER     "${MQTT_SERVER}"
#define MQTT_USER       "admin"
#define MQTT_PASS       "${MQTT_PASS}"

#define BACKEND_URL     "${BACKEND_URL}"
EOF

    cat > "$CAMERA_SECRETS" <<EOF
#pragma once

#define SECRET_SSID  "${WIFI_SSID}"
#define SECRET_PASS  "${WIFI_PASS}"
#define BACKEND_URL  "${BACKEND_URL}"
EOF

    cat > "$UI_ENV" <<EOF
INFLUXDB_URL=${INFLUXDB_URL}
INFLUXDB_TOKEN=${INFLUXDB_TOKEN}
INFLUXDB_DATABASE=${INFLUXDB_DATABASE}

MQTT_URL=mqtt://${MQTT_SERVER}:1883
MQTT_USER=admin
MQTT_PASS=${MQTT_PASS}

NUXT_AUTH_USERNAME=admin
NUXT_AUTH_PASSWORD=${UI_PASS}
NUXT_SESSION_PASSWORD=${SESSION_PASS}
EOF

    python3 - "$SCRIPT_DIR/docker/nodered/flows.json" "$INFLUXDB_TOKEN" <<'PYEOF'
import json, re, sys
path, token = sys.argv[1], sys.argv[2]
with open(path) as f:
    flows = json.load(f)
for node in flows:
    if node.get('type') == 'mqtt-broker':
        node['port'] = '1884'
    if node.get('type') == 'function':
        node['func'] = re.sub(
            r'Token apiv3_[a-zA-Z0-9_]+',
            'Token ' + token,
            node.get('func', '')
        )
with open(path, 'w') as f:
    json.dump(flows, f, indent=4)
PYEOF

    echo ""
    echo -e "${GREEN}Config files written:${NC}"
    echo "  firmware/sensor/include/secrets.h"
    echo "  firmware/camera/include/secrets.h"
    echo "  ui/.env"
    echo "  docker/admin.token"
    echo "  docker/mosquitto/config/passwordfile"
    echo "  docker/mosquitto/config/mosquitto.conf"
    echo "  docker/nodered/flows.json"
    echo ""

    echo -e "${BOLD}Installing UI dependencies…${NC}"
    cd "$SCRIPT_DIR/ui" && npm install

    echo ""
    echo -e "${BOLD}Building UI…${NC}"
    npm run build

    echo ""
    echo -e "${GREEN}Setup complete.${NC}"
    echo ""
    echo -e "${BOLD}Next steps${NC}"
    echo "  Flash sensor:   cd firmware/sensor && pio run -e esp-wrover-kit -t upload"
    echo "  Flash camera:   cd firmware/camera && pio run -e esp32cam    -t upload"
    echo "  Start Warren:   ./warren start"
    echo ""
}

start() {
    local dev=false
    [[ "${1:-}" == "--dev" ]] && dev=true

    echo -e "${BOLD}Warren — Start${NC}"
    echo ""

    if [[ ! -f "$UI_ENV" ]]; then
        echo -e "${RED}ui/.env not found. Run 'warren setup' first.${NC}"
        exit 1
    fi

    if [[ ! -f "$INFLUXDB_TOKEN_FILE" ]]; then
        echo -e "${RED}docker/admin.token not found. Run 'warren setup' first.${NC}"
        exit 1
    fi

    if [[ -f "$PID_FILE" ]]; then
        local pid
        pid="$(cat "$PID_FILE")"
        if kill -0 "$pid" 2>/dev/null; then
            echo -e "${YELLOW}UI already running (PID $pid). Run 'warren stop' first.${NC}"
            exit 1
        else
            rm -f "$PID_FILE"
        fi
    fi

    echo -e "${BOLD}Starting infrastructure…${NC}"
    cd "$SCRIPT_DIR/docker" && docker compose up -d
    echo ""

    if $dev; then
        echo -e "${BOLD}Starting UI in dev mode (Ctrl+C to stop UI; run 'warren stop' to also stop infrastructure)…${NC}"
        echo ""
        cd "$SCRIPT_DIR/ui" && npm run dev
    else
        echo -e "${BOLD}Starting UI…${NC}"
        (set -a; source "$SCRIPT_DIR/ui/.env"; set +a; cd "$SCRIPT_DIR/ui"; exec node .output/server/index.mjs) &
        echo $! > "$PID_FILE"
        echo -e "${GREEN}UI started (PID $(cat "$PID_FILE"))${NC}"
        echo ""
        echo -e "Run ${BOLD}warren stop${NC} to shut everything down."
    fi
}

stop() {
    echo -e "${BOLD}Warren — Stop${NC}"
    echo ""

    if [[ -f "$PID_FILE" ]]; then
        local pid
        pid="$(cat "$PID_FILE")"
        if kill -0 "$pid" 2>/dev/null; then
            echo "Stopping UI (PID $pid)…"
            kill "$pid"
            wait "$pid" 2>/dev/null || true
        else
            echo -e "${YELLOW}UI process (PID $pid) not found — already stopped.${NC}"
        fi
        rm -f "$PID_FILE"
    else
        echo "No UI PID file found — UI was not started by this script or already stopped."
    fi

    echo "Stopping infrastructure…"
    cd "$SCRIPT_DIR/docker" && docker compose stop
    echo ""
    echo -e "${GREEN}Done.${NC}"
}

cleanup() {
    echo -e "${BOLD}Warren — Cleanup${NC}"
    echo -e "${RED}This will permanently delete all data, secrets, and tokens:${NC}"
    echo "  Docker volumes (InfluxDB data, Node-RED flows)"
    echo "  firmware/sensor/include/secrets.h"
    echo "  firmware/camera/include/secrets.h"
    echo "  ui/.env"
    echo "  docker/admin.token"
    echo "  docker/mosquitto/config/passwordfile"
    echo "  ui/.data/  (SQLite database including user password)"
    echo ""
    IFS= read -r -p "Type YES to confirm: " confirm
    [[ "$confirm" == "YES" ]] || { echo "Aborted."; exit 1; }
    echo ""

    if [[ -f "$PID_FILE" ]]; then
        local pid
        pid="$(cat "$PID_FILE")"
        if kill -0 "$pid" 2>/dev/null; then
            echo "Stopping UI (PID $pid)…"
            kill "$pid"
            wait "$pid" 2>/dev/null || true
        fi
        rm -f "$PID_FILE"
    fi

    echo "Stopping infrastructure and removing volumes…"
    cd "$SCRIPT_DIR/docker" && docker compose down -v
    echo ""

    echo "Removing secrets and tokens…"
    rm -f "$SENSOR_SECRETS" "$CAMERA_SECRETS" "$UI_ENV" "$INFLUXDB_TOKEN_FILE" "$MQTT_PASSWORDFILE"
    rm -rf "$SQLITE_DATA_DIR"

    cat > "$MQTT_CONF" <<'EOF'
listener 1883
allow_anonymous true
EOF

    echo ""
    echo -e "${GREEN}Cleanup complete. Run 'warren setup' to start fresh.${NC}"
    echo ""
}

case "${1:-}" in
    setup)   setup ;;
    start)   start "${2:-}" ;;
    stop)    stop ;;
    cleanup) cleanup ;;
    *)       usage ;;
esac
