# Next.js (canonical nextjs-ui/)
nextjs-ui/.next
nextjs-ui/.data
nextjs-ui/.data-e2e
nextjs-ui/node_modules
nextjs-ui/logs
nextjs-ui/*.log
nextjs-ui/.env
nextjs-ui/.env.*
!nextjs-ui/.env.example
nextjs-ui/playwright-report
nextjs-ui/test-results

# PlatformIO
firmware/**/.pio
firmware/**/.vscode
firmware/**/.cache
firmware/**/include/secrets.h

# Docker secrets
docker/admin.token
docker/mosquitto/config/passwordfile
docker/nodered/flows.json

# Caddy / TLS — generated by `warren setup`
docker/.env
docker/caddy/Caddyfile
docker/caddy/site/*
!docker/caddy/site/.gitkeep
docker/tls/*
!docker/tls/.gitkeep

# OS
.DS_Store

# Warren runtime
.warren.pid
